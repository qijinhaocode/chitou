generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  clerkId    String   @unique
  email      String   @unique
  name       String
  avatarUrl  String?
  targetDate DateTime?
  dailyGoal  Int      @default(10)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cards      Card[]
  reviewLogs ReviewLog[]
}

// ─── Card ─────────────────────────────────────────────────────────────────────

model Card {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  title           String
  question        String      @db.Text
  referenceAnswer String      @db.Text
  tags            String[]
  category        CardCategory @default(custom)
  difficulty      Int         @default(3)  // 1-5

  // FSRS scheduling
  fsrsState       FSRSState   @default(new)
  stability       Float       @default(0)
  fsrsDifficulty  Float       @default(0)
  elapsedDays     Int         @default(0)
  scheduledDays   Int         @default(0)
  reps            Int         @default(0)
  lapses          Int         @default(0)
  due             DateTime    @default(now())

  // Display
  masteryStatus   MasteryStatus @default(pending)
  lastScore       Int?          // 0-100

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  reviewLogs      ReviewLog[]

  @@index([userId, due])
  @@index([userId, masteryStatus])
}

// ─── ReviewLog ────────────────────────────────────────────────────────────────

model ReviewLog {
  id                 String   @id @default(cuid())
  cardId             String
  card               Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAnswer         String   @db.Text

  // AI evaluation
  overallScore       Int
  accuracyScore      Int
  completenessScore  Int
  logicScore         Int
  aiFeedback         String   @db.Text
  aiSuggestion       String   @db.Text

  // FSRS rating applied
  rating             Int      // 1=Again, 2=Hard, 3=Good, 4=Easy

  // FSRS snapshot before this review (stored as JSON)
  fsrsStateBefore    Json

  reviewedAt         DateTime @default(now())

  @@index([userId, reviewedAt])
  @@index([cardId])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum FSRSState {
  new
  learning
  review
  relearning
}

enum MasteryStatus {
  pending
  digesting
  mastered
}

enum CardCategory {
  algorithm
  system_design
  behavioral
  language
  database
  network
  os
  custom
}
